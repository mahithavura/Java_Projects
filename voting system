import java.util.*;
import java.io.*;
class Candidate {
    String name;

    Candidate(String name) {
        this.name = name;
    }
}

public class VotingSystem {

    static HashMap<String, Integer> votes = new HashMap<>();
    static HashSet<String> voters = new HashSet<>(); 
    static Scanner sc = new Scanner(System.in);
    public static void addCandidate() {
        System.out.print("Enter candidate name: ");
        String name = sc.next();
        votes.put(name, 0);
        System.out.println("Candidate added successfully!");
    }
    public static void castVote() {
        try {
            System.out.print("Enter voter ID: ");
            String voterId = sc.next();

            if (voters.contains(voterId)) {
                System.out.println("You have already voted!");
                return;
            }

            System.out.print("Enter candidate name: ");
            String name = sc.next();

            if (votes.containsKey(name)) {
                votes.put(name, votes.get(name) + 1);
                voters.add(voterId);
                System.out.println("Vote cast successfully!");
            } else {
                System.out.println("Candidate not found!");
            }
        } catch (Exception e) {
            System.out.println("Invalid input!");
        }
    }

    public static void displayResults() {
        System.out.println("\n--- Voting Results ---");
        for (String candidate : votes.keySet()) {
            System.out.println(candidate + " : " + votes.get(candidate));
        }
    }

    public static void announceWinner() {
        int maxVotes = -1;
        String winner = "";

        for (String candidate : votes.keySet()) {
            if (votes.get(candidate) > maxVotes) {
                maxVotes = votes.get(candidate);
                winner = candidate;
            }
        }

        if (maxVotes == -1) {
            System.out.println("No votes yet!");
        } else {
            System.out.println("Winner is: " + winner + " with " + maxVotes + " votes");
        }
    }

    public static void saveToFile() {
        try {
            FileWriter fw = new FileWriter("results.txt");
            for (String candidate : votes.keySet()) {
                fw.write(candidate + " : " + votes.get(candidate) + "\n");
            }
            fw.close();
            System.out.println("Results saved to file!");
        } catch (IOException e) {
            System.out.println("Error writing file!");
        }
    }

    public static void main(String[] args) {
        int choice;

        do {
            System.out.println("\n--- Voting System ---");
            System.out.println("1. Add Candidate");
            System.out.println("2. Cast Vote");
            System.out.println("3. Display Results");
            System.out.println("4. Announce Winner");
            System.out.println("5. Save Results to File");
            System.out.println("6. Exit");

            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    addCandidate();
                    break;
                case 2:
                    castVote();
                    break;
                case 3:
                    displayResults();
                    break;
                case 4:
                    announceWinner();
                    break;
                case 5:
                    saveToFile();
                    break;
                case 6:
                    System.out.println("Exiting...");
                    break;
                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 6);
    }
                  }
